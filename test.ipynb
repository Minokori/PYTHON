    "from collections import deque\n",
    "import torch\n",
    "\n",
    "a = deque(maxlen=3)\n",
    "\n",
    "a.append(torch.rand(3))\n",
    "a.append(torch.rand(3))\n",
    "\n",
    "len(a)"
   ]
  },
