   "source": [
    "class A:\n",
    "    def __init__(self, x, y):\n",
    "        self.x = x\n",
    "        self.y = y\n",
    "\n",
    "    def __str__(self) -> str:\n",
    "        return f\"A(x={self.x}, y={self.y})\"\n",
    "\n",
    "\n",
    "def add(a: A, x: float, y: float) -> A:\n",
    "    a.x += x\n",
    "    a.y += y\n",
    "    return a\n",
    "\n",
    "\n",
    "a = A(1, 2)\n",
    "a.add(3, 4)\n",
    "print(a)"
   ]
